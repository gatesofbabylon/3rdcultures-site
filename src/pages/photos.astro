---
import fs from "node:fs";
import path from "node:path";
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "Photos by Phil Pearson.",
	title: "Photos",
};

const photosDir = path.join(process.cwd(), "public/images/photos");
const allFiles = fs.readdirSync(photosDir);
const photos = allFiles
	.filter((f) => /\.(jpg|jpeg|png|gif|webp)$/i.test(f))
	.sort();

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<PageLayout meta={meta}>
	<h1 class="title mb-12">Photos</h1>
	<div class="grid grid-cols-2 gap-2 sm:grid-cols-3">
		{
			photos.map((filename) => (
				<a
					href={`${base}/images/photos/${filename}`}
					target="_blank"
					rel="noopener noreferrer"
				>
					<img
						src={`${base}/images/photos/${filename}`}
						alt=""
						class="aspect-square w-full object-cover"
						loading="lazy"
					/>
				</a>
			))
		}
	</div>
</PageLayout>
